# OpenRouter - FREE AI models (https://openrouter.ai - free signup, no credit card)
OPENROUTER_API_KEY=your_openrouter_key_here

# OpenAI (optional fallback, paid)
OPENAI_API_KEY=your_openai_key_here

# MongoDB
MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/devtrack

# ChromaDB local vector store
CHROMA_PERSIST_DIR=./chroma_store

# Free LLM via OpenRouter
LLM_MODEL=google/gemini-2.0-flash-exp:free

# Embeddings are LOCAL (ONNX model, no API key needed)
EMBEDDING_MODEL=local-onnx

MAX_TOKENS=4096
CHUNK_SIZE=500
CHUNK_OVERLAP=50
TOP_K_RETRIEVAL=5
PORT=8000
